PORT=8000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=80
MAX_TOTAL_UPLOAD_MB=250
FILE_TTL_SECONDS=86400
CLEANUP_ON_REQUEST=true
APP_TITLE=PDF Mini App

ENABLE_BASIC_AUTH=false
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

USE_S3=false
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

LOG_LEVEL=INFO
